                                    .header:has(.main-header-wrapper .active-parent-link.link-{{ link_handle }}) .bottom-bar--border:has(.menu.menu-{{ link_handle }}) {
                                        border-block-start: var(--line-thickness) solid rgb(var(--lines-color));
                                        padding-top: var(--middle-padding);
                                        padding-bottom: var(--middle-padding);
                                    }
                                    .header:has(.bottom-bar .menu.menu-{{ link_handle }}) .main-header-wrapper.reduce-padding {
                                        padding-bottom: var(--top-and-bottom-paddings);
                                    }
                                    .shopify-section-header:has(.main-header-wrapper .active-parent-link.link-{{ link_handle }}) .header:has(.bottom-bar .menu.menu-{{ link_handle }}) .main-header-wrapper.reduce-padding {
