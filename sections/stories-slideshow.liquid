{% if section.blocks.size > 0 %}
{{ 'stories-slider.min.css' | asset_url | stylesheet_tag }}
{{ 'effect-carousel.min.css' | asset_url | stylesheet_tag }}

{%- liquid
    assign disable_max_width = false
    if section.settings.disable_max_width 
        assign disable_max_width = true
    elsif section.settings.grid_style == 'page' and settings.full_width_page_grid
        assign disable_max_width = true
    elsif section.settings.grid_style == 'alternative' and settings.full_width_alt_grid
        assign disable_max_width = true
    elsif section.settings.grid_style == 'secondary' and settings.full_width_second_grid
        assign disable_max_width = true
    endif

    assign full_width = false
    if section.settings.full_width
      assign full_width = true
    endif

    assign section_framing = false
    if section.settings.section_framing != 'disable'
        assign section_framing = true
    endif

    assign uppercase_title = false
    if section.settings.title_style == 'subheading-font' and settings.uppercase_subheadings
        assign uppercase_title = true
    elsif section.settings.title_style == 'body-font' and settings.uppercase_body
        assign uppercase_title = true
    elsif section.settings.title_style == 'caption-font' and settings.uppercase_caption
        assign uppercase_title = true
    endif

    assign accent_price = false
    if settings.bolder_product_price and section.settings.card_content_style == 'regular'
        assign accent_price = true
    endif
    if settings.small_bolder_product_price and section.settings.card_content_style == 'small'
        assign accent_price = true
    endif
    assign use_accent_color_for_price = false
    if settings.use_accent_color_for_price and section.settings.card_content_style == 'regular'
        assign use_accent_color_for_price = true
    elsif settings.small_use_accent_color_for_price and section.settings.card_content_style == 'small'
        assign use_accent_color_for_price = true
    endif
    assign use_sale_color_for_new_price = false
    if settings.use_sale_color_for_new_price and section.settings.card_content_style == 'regular'
        assign use_sale_color_for_new_price = true
    elsif settings.small_use_sale_color_for_new_price and section.settings.card_content_style == 'small'
        assign use_sale_color_for_new_price = true
    endif
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    --top-spacing: {{ section.settings.top_spacing }};
    --bottom-spacing: {{ section.settings.bottom_spacing }};
    --aspect-ratio: 1 / 1;
    {%- if section.settings.thunbnails_image_radius == 'default' -%}
        --thumbnails-image-radius: {{ settings.images_and_sections_radius }};
    {%- else -%}
        --thumbnails-image-radius: {{ section.settings.thunbnails_image_radius }};
    {%- endif -%}
    --thumbnail-width: {{ section.settings.thumbnails_width }}px;
    --grid-columns: 2;
    {% if section.settings.thumbnail_border_gradient != empty %}
      --thumbnail-border-gradient: {% if section.settings.thumbnail_border_gradient == blank %}{{ section.settings.thumbnail_border_color | color_to_rgb | strip }}{% else %}{{ section.settings.thumbnail_border_gradient }}{% endif %};
    {% else %}
      --thumbnail-border-gradient: {{ section.settings.thumbnail_border_color | color_to_rgb | strip }};
    {% endif %}
  }
  @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} {
            --thumbnail-width: {{ section.settings.mobile_thumbnails_width }}px;
        }
    }
{% endstyle %}

<div class="section{% if section_framing == false or section.settings.full_width %} color-{{ section.settings.color_scheme }}{% endif %} {% unless section.settings.full_width %} side-margins{% endunless %}{% if section.settings.show_bottom_line %} bottom-line{% endif %}">
    <div class="section-container{% if section.settings.full_width == false %}{% if section.settings.section_framing == 'grid' %} {{ section.settings.grid_style }}-grid{% if disable_max_width %} disable-max-width{% endif %}{% endif %}{% unless section_framing %} {{ section.settings.grid_style }}-grid{% if disable_max_width %} disable-max-width{% endif %}{% endunless %}{% endif %}">
      {% if section_framing and section.settings.full_width == false %}<div class="section-radius elem-padding-l color-{{ section.settings.color_scheme }}"><div {% if section.settings.section_framing != 'grid' %}class="{{ section.settings.grid_style }}-grid{% if disable_max_width %} disable-max-width{% endif %}"{% endif %}>{% endif %}
        {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
          <div class="{% if section.settings.full_width %}side-margins{% endif %}{% if section.settings.center_text %} center{% endif %}">
            <div class="section-header {% if section.settings.full_width %} {{ section.settings.grid_style }}-grid{% if disable_max_width %} disable-max-width{% endif %}{% endif %}">
                {%- if section.settings.subheading != blank -%}
                    {%- liquid
                      assign uppercase_subheading = false
                      if section.settings.subheading_style == 'section-heading' and settings.uppercase_section_headings
                          assign uppercase_subheading = true
                      elsif section.settings.subheading_style == 'secondary-heading' and settings.uppercase_secondary_headings
                          assign uppercase_subheading = true
                      elsif section.settings.subheading_style == 'subheading-font' and settings.uppercase_subheadings
                          assign uppercase_subheading = true
                      elsif section.settings.subheading_style == 'body-font' and settings.uppercase_body
                          assign uppercase_subheading = true
                      elsif section.settings.subheading_style == 'caption-font' and settings.uppercase_caption
                          assign uppercase_subheading = true
                      endif
                    -%}
                    <{{ section.settings.subheading_tag }} class="{{ section.settings.subheading_style }}{% if uppercase_subheading %} uppercase{% endif %} 
                      {% if section.settings.subheading_style == 'subheading-font' %}{% if settings.use_heading_font_subheadings %} subheading-heading-font{% endif %}{% endif %}">
                      {% if section.settings.subheading_style == 'subheading-font' and settings.bolder_subheadings_font %}<b>{% endif %}
                        {{ section.settings.subheading }}
                      {% if section.settings.subheading_style == 'subheading-font' and settings.bolder_subheadings_font %}</b>{% endif %}
                    </{{ section.settings.subheading_tag }}>
                {%- endif -%}
                  {%- if section.settings.heading != blank -%}
                    {%- liquid
                      assign uppercase_heading = false
                      if section.settings.heading_style == 'secondary-heading' and settings.uppercase_secondary_headings
                          assign uppercase_heading = true
                      elsif section.settings.heading_style == 'section-heading' and settings.uppercase_section_headings
                          assign uppercase_heading = true
                      elsif section.settings.heading_style == 'page-title' and settings.uppercase_page_titles
                          assign uppercase_heading = true
                      elsif section.settings.heading_style == 'subheading-font' and settings.uppercase_subheadings
                          assign uppercase_heading = true
                      elsif section.settings.heading_style == 'body-font' and settings.uppercase_body
                          assign uppercase_heading = true
                      elsif section.settings.heading_style == 'caption-font' and settings.uppercase_caption
                          assign uppercase_heading = true
                      endif
                    -%}
                    <{{ section.settings.heading_tag }} class="{{ section.settings.heading_style }}{% if uppercase_heading %} uppercase{% endif %}{% if section.settings.heading_style == 'subheading-font' and settings.use_heading_font_subheadings %} subheading-heading-font{% endif %}">
                      {% if section.settings.heading_style == 'subheading-font' and settings.bolder_subheadings_font %}<b>{% endif %}{{ section.settings.heading }}{% if section.settings.heading_style == 'subheading-font' and settings.bolder_subheadings_font %}</b>{% endif %}
                    </{{ section.settings.heading_tag }}>
                {%- endif -%}
            </div>
          </div>
        {%- endif -%}
        <stories-slideshow data-autoplay-speed="{{ section.settings.story_autoplay_speed | times: 1000 }}" data-section-id="{{ section.id }}" style="--active-slide-duration: {{ section.settings.story_autoplay_speed }}s;"
            class="stories-slideshow {% unless full_width %} {{ section.settings.grid_style }}-grid{% endunless %}{% if section.settings.full_width %} stories-slideshow--full-width{% endif %}">
            <div class="stories-slideshow__thumbnails-wrapper">
              <div class="stories-slideshow__thumbnails hide-scrollbar flex--row {{ section.settings.grid_style }}-grid-gaps">
                  {%- for block in section.blocks -%}
                    {% liquid
                      assign total_slides = 0
                      if block.settings.image_1 != blank
                        assign total_slides = total_slides | plus: 1
                      endif
                      if block.settings.image_2 != blank
                        assign total_slides = total_slides | plus: 1
                      endif
                      if block.settings.image_3 != blank
                        assign total_slides = total_slides | plus: 1
                      endif
                      if block.settings.image_4 != blank
                        assign total_slides = total_slides | plus: 1
                      endif
                      if block.settings.image_5 != blank
                        assign total_slides = total_slides | plus: 1
                      endif
                      if block.settings.image_6 != blank
                        assign total_slides = total_slides | plus: 1
                      endif
                      if block.settings.image_7 != blank
                        assign total_slides = total_slides | plus: 1
                      endif
                      if block.settings.image_8 != blank
                        assign total_slides = total_slides | plus: 1
                      endif
                    %}
                      {%- if block.settings.thumbnail_image != blank or request.design_mode -%}
                      <button class="stories-slideshow__thumbnail {% if total_slides == 0 %} events-none{% endif %}" data-thumbnail-id="{{ block.id }}" {{ block.shopify_attributes }}>
                          <div class="stories-slideshow__circle-wrapper aspect-ratio">
                              <div class="stories-slideshow__circle aspect-ratio"{% if settings.disable_right_click %} oncontextmenu="return false"{% endif %}>
                                  {% if block.settings.thumbnail_image != blank %}
                                      {%- liquid
                                          assign widths = '150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250'
                                          assign img_class = "stories-slideshow__thumbnail-image"
                                      -%}
                                      {%- capture sizes -%}
                                          (max-width: 768px) {{ section.settings.mobile_thumbnails_width }}px, {{ section.settings.thumbnails_width }}px
                                      {%- endcapture -%}
                                      {{
                                          block.settings.thumbnail_image
                                          | image_url: width: 1500
                                          | image_tag:
                                          sizes: sizes,
                                          widths: widths,
                                          class: img_class,
                                          alt: block.settings.thumbnail_image.alt,
                                          draggable: false
                                      }}
                                  {% else %}
                                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                                  {% endif %}
                              </div>
                          </div>
                          {% if block.settings.title != blank %}
                              <div class="stories-slideshow__title {{ section.settings.title_style }}{% if uppercase_title %} uppercase{% endif %}{% if section.settings.title_style == 'subheading-font' and settings.use_heading_font_subheadings %} subheading-heading-font{% endif %}">
                                  {% if section.settings.title_style == 'subheading-font' and settings.bolder_subheadings_font %}<b>{% endif %}{{ block.settings.title }}{% if section.settings.title_style == 'subheading-font' and settings.bolder_subheadings_font %}</b>{% endif %}
                              </div>
                          {% endif %}
                      </button>
                      {%- endif -%}
                  {%- endfor -%}
              </div>
            </div>
            <div class="stories-slideshow__stories">
                <div class="stories-slider visually-hidden">
                    <div class="swiper swiper-stories">
                      <div class="swiper-wrapper swiper-wrapper-stories">
                        {% for block in section.blocks %}
                          {% liquid
                            assign total_slides = 0
                            if block.settings.image_1 != blank
                              assign total_slides = total_slides | plus: 1
                            endif
                            if block.settings.image_2 != blank
                              assign total_slides = total_slides | plus: 1
                            endif
                            if block.settings.image_3 != blank
                              assign total_slides = total_slides | plus: 1
                            endif
                            if block.settings.image_4 != blank
                              assign total_slides = total_slides | plus: 1
                            endif
                            if block.settings.image_5 != blank
                              assign total_slides = total_slides | plus: 1
                            endif
                            if block.settings.image_6 != blank
                              assign total_slides = total_slides | plus: 1
                            endif
                            if block.settings.image_7 != blank
                              assign total_slides = total_slides | plus: 1
                            endif
                            if block.settings.image_8 != blank
                              assign total_slides = total_slides | plus: 1
                            endif
                          %}
                          {% if total_slides > 0 %}
                          <div class="swiper-slide stories-slides" data-slide-id="{{ block.id }}">
                            <div class="swiper swiper-story-inner">
                              {% if block.settings.thumbnail_image != blank or request.design_mode %}
                                <div class="stories-slider__user flex--row color-{{ section.settings.banner_color_scheme }}">
                                  <div class="stories-slider__user-avatar"{% if settings.disable_right_click %} oncontextmenu="return false"{% endif %}>
                                      {% if block.settings.thumbnail_image != blank %}
                                          {%- liquid
                                              assign widths = '100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500'
                                              assign img_class = "stories-slideshow__avatar"
                                          -%}
                                          {%- capture sizes -%}
                                              (max-width: 768px) 32px, 32px
                                          {%- endcapture -%}
                                          {{
                                              block.settings.thumbnail_image
                                              | image_url: width: 1500
                                              | image_tag:
                                              sizes: sizes,
                                              widths: widths,
                                              class: img_class,
                                              alt: block.settings.thumbnail_image.alt,
                                              draggable: false
                                          }}
                                      {% else %}
                                          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                                      {% endif %}
                                  </div>
                                  {% if block.settings.title != blank %}
                                      <div class="stories-slider__user-name {{ section.settings.title_style }}{% if uppercase_title %} uppercase{% endif %}{% if section.settings.title_style == 'subheading-font' and settings.use_heading_font_subheadings %} subheading-heading-font{% endif %}">
                                          {% if section.settings.title_style == 'subheading-font' and settings.bolder_subheadings_font %}<b>{% endif %}{{ block.settings.title }}{% if section.settings.title_style == 'subheading-font' and settings.bolder_subheadings_font %}</b>{% endif %}
                                          <div class="stories-slider__user-name stories-slider__user-name-absolut {{ section.settings.title_style }}{% if uppercase_title %} uppercase{% endif %}{% if section.settings.title_style == 'subheading-font' and settings.use_heading_font_subheadings %} subheading-heading-font{% endif %}">
                                            {% if section.settings.title_style == 'subheading-font' and settings.bolder_subheadings_font %}<b>{% endif %}{{ block.settings.title }}{% if section.settings.title_style == 'subheading-font' and settings.bolder_subheadings_font %}</b>{% endif %}
                                        </div>
                                      </div>
                                  {% endif %}
                              </div>
                            {% endif %}
                                <div class="swiper-wrapper ">
                                    {% if block.settings.image_1 != blank %}
                                        {% render 'stories-slide', 
                                          block: block, 
                                          image: block.settings.image_1, 
                                          link: block.settings.link_1, 
                                          target_blank: block.settings.target_blank_1, 
                                          label: block.settings.label_1, 
                                          button_style: block.settings.button_style_1, 
                                          use_main_button: block.settings.use_main_button_1, 
                                          products: block.settings.products_1, 
                                          index: 1,
                                          accent_price: accent_price,
                                          use_sale_color_for_new_price: use_sale_color_for_new_price, 
                                          use_accent_color_for_price: use_accent_color_for_price
                                         %}
                                    {% endif %}
                                    {% if block.settings.image_2 != blank %}
                                        {% render 'stories-slide', block: block, 
                                          image: block.settings.image_2, 
                                          link: block.settings.link_2, 
                                          target_blank: block.settings.target_blank_2, 
                                          label: block.settings.label_2, 
                                          button_style: block.settings.button_style_2, 
                                          use_main_button: block.settings.use_main_button_2, 
                                          products: block.settings.products_2, 
                                          index: 2,
                                          accent_price: accent_price,
                                          use_sale_color_for_new_price: use_sale_color_for_new_price, 
                                          use_accent_color_for_price: use_accent_color_for_price
                                         %}
                                    {% endif %}
                                    {% if block.settings.image_3 != blank %}
                                        {% render 'stories-slide', block: block, 
                                          image: block.settings.image_3,  
                                          link: block.settings.link_3, 
                                          target_blank: block.settings.target_blank_3, 
                                          label: block.settings.label_3, 
                                          button_style: block.settings.button_style_3, 
                                          use_main_button: block.settings.use_main_button_3, 
                                          products: block.settings.products_3,
                                          index: 3,
                                          accent_price: accent_price,
                                          use_sale_color_for_new_price: use_sale_color_for_new_price, 
                                          use_accent_color_for_price: use_accent_color_for_price
                                         %}
                                    {% endif %}
                                    {% if block.settings.image_4 != blank %}
                                        {% render 'stories-slide', block: block, 
                                          image: block.settings.image_4, 
                                          link: block.settings.link_4, 
                                          target_blank: block.settings.target_blank_4, 
                                          label: block.settings.label_4, 
                                          button_style: block.settings.button_style_4, 
                                          use_main_button: block.settings.use_main_button_4, 
                                          products: block.settings.products_4, 
                                          index: 4,
                                          accent_price: accent_price,
                                          use_sale_color_for_new_price: use_sale_color_for_new_price, 
                                          use_accent_color_for_price: use_accent_color_for_price
                                         %}
                                    {% endif %}
                                    {% if block.settings.image_5 != blank %}
                                        {% render 'stories-slide', block: block, 
                                          image: block.settings.image_5, 
                                          link: block.settings.link_5, 
                                          target_blank: block.settings.target_blank_5, 
                                          label: block.settings.label_5, 
                                          button_style: block.settings.button_style_5, 
                                          use_main_button: block.settings.use_main_button_5, 
                                          products: block.settings.products_5,
                                          index: 5,
                                          accent_price: accent_price,
                                          use_sale_color_for_new_price: use_sale_color_for_new_price, 
                                          use_accent_color_for_price: use_accent_color_for_price
                                         %}
                                    {% endif %}
                                    {% if block.settings.image_6 != blank %}
                                        {% render 'stories-slide', block: block, 
                                          image: block.settings.image_6, 
                                          link: block.settings.link_6, 
                                          target_blank: block.settings.target_blank_6, 
                                          label: block.settings.label_6, 
                                          button_style: block.settings.button_style_6, 
                                          use_main_button: block.settings.use_main_button_6, 
                                          products: block.settings.products_6,
                                          index: 6,
                                          accent_price: accent_price,
                                          use_sale_color_for_new_price: use_sale_color_for_new_price, 
                                          use_accent_color_for_price: use_accent_color_for_price
                                         %}
                                    {% endif %}
                                    {% if block.settings.image_7 != blank %}
                                        {% render 'stories-slide', block: block, 
                                          image: block.settings.image_7, 
                                          link: block.settings.link_7, 
                                          target_blank: block.settings.target_blank_7, 
                                          label: block.settings.label_7, 
                                          button_style: block.settings.button_style_7, 
                                          products: block.settings.products_7, 
                                          use_main_button: block.settings.use_main_button_7, 
                                          index: 7,
                                          accent_price: accent_price,
                                          use_sale_color_for_new_price: use_sale_color_for_new_price, 
                                          use_accent_color_for_price: use_accent_color_for_price
                                         %}
                                    {% endif %}
                                    {% if block.settings.image_8 != blank %}
                                        {% render 'stories-slide', block: block, 
                                          image: block.settings.image_8, 
                                          link: block.settings.link_8, 
                                          target_blank: block.settings.target_blank_8, 
                                          label: block.settings.label_8, 
                                          button_style: block.settings.button_style_8, 
                                          products: block.settings.products_8, 
                                          use_main_button: block.settings.use_main_button_8, 
                                          index: 8,
                                          accent_price: accent_price,
                                          use_sale_color_for_new_price: use_sale_color_for_new_price, 
                                          use_accent_color_for_price: use_accent_color_for_price
                                         %}
                                    {% endif %}
                                </div>
                                <div class="stories-slider-pagination color-{{ section.settings.banner_color_scheme }}" style="--total-slides: {{ total_slides }}"></div>
                            </div>
                          </div>
                          {% endif %}
                        {% endfor %}
                      </div>
                      <div class="stories-slider-actions color-background-1">
                        <button class="stories-slider-close-button button button-close button--small close-popup icon--large" aria-label="{{ 'accessibility.close' | t }}">
                            {%- render 'glyphs_interface', icon: 'close' -%}
                        </button>
                      </div>
                    </div>
                </div>
            </div>
        </stories-slideshow>
        {% if section_framing and section.settings.full_width == false %}</div></div>{% endif %}
    </div>
</div>

<script src="{{ 'stories-slider.min.js' | asset_url }}" defer></script>
<script src="{{ 'effect-carousel.min.js' | asset_url }}" defer></script>

{% endif %}

{% schema %}
{
  "name": "t:sections.stories-slideshow.name",
  "tag": "section",
  "class": "section-stories-slideshow",
  "settings": [
    {
        "type": "text",
        "id": "subheading",
        "label": "t:sections.all.settings_titles.subheading.subheading.label"
    },
    {
        "type": "select",
        "id": "subheading_style",
        "options": [
          {
            "value": "caption-font",
            "label": "t:sections.all.headings_style.options__6.label"
          },
          {
            "value": "body-font",
            "label": "t:sections.all.headings_style.options__1.label"
          },
          {
            "value": "subheading-font",
            "label": "t:sections.all.headings_style.options__2.label"
          },
          {
            "value": "secondary-heading",
            "label": "t:sections.all.headings_style.options__3.label"
          },
          {
            "value": "section-heading",
            "label": "t:sections.all.headings_style.options__4.label"
          }
        ],
        "default": "subheading-font",
        "label": "t:sections.all.headings_style.subheading_style.label"
    },
    {
        "type": "select",
        "id": "subheading_tag",
        "options": [
          {
              "value": "h1",
              "label": "t:sections.all.tag.options__1.label"
          },
          {
              "value": "h2",
              "label": "t:sections.all.tag.options__2.label"
          },
          {
              "value": "h3",
              "label": "t:sections.all.tag.options__3.label"
          },
          {
              "value": "h4",
              "label": "t:sections.all.tag.options__4.label"
          },
          {
              "value": "h5",
              "label": "t:sections.all.tag.options__5.label"
          },
          {
              "value": "h6",
              "label": "t:sections.all.tag.options__6.label"
          },
          {
              "value": "div",
              "label": "t:sections.all.tag.options__7.label"
          },
          {
              "value": "span",
              "label": "t:sections.all.tag.options__8.label"
          }, 
          {
              "value": "p",
              "label": "t:sections.all.tag.options__9.label"
          }
          ],
          "default": "h3",
          "label": "t:sections.all.tag.subheading_tag.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.all.settings_titles.heading.heading.label"
    },
    {
      "type": "select",
      "id": "heading_style",
      "options": [
        {
          "value": "caption-font",
          "label": "t:sections.all.headings_style.options__6.label"
        },
        {
          "value": "body-font",
          "label": "t:sections.all.headings_style.options__1.label"
        },
        {
          "value": "subheading-font",
          "label": "t:sections.all.headings_style.options__2.label"
        },
        {
          "value": "secondary-heading",
          "label": "t:sections.all.headings_style.options__3.label"
        },
        {
          "value": "section-heading",
          "label": "t:sections.all.headings_style.options__4.label"
        },
        {
          "value": "page-title",
          "label": "t:sections.all.headings_style.options__5.label"
        }
      ],
      "default": "page-title",
      "label": "t:sections.all.headings_style.heading_style.label"
