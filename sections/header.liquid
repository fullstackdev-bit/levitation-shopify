{% style %}
    #shopify-section-{{ section.id }} {
        --top-and-bottom-paddings: {{ section.settings.desktop_top_and_bottom_spacing }}px;
        --middle-padding: {{ section.settings.middle_spacing }}px;
        --mobile-middle-padding: {{ section.settings.mobile_middle_spacing }}px;
    }
    .header {
        transition: background-color .3s var(--transition-timing-function);
    }
    @media screen and (min-width: 769px) and (hover: hover) {
        {% if section.settings.search_make_translucent %}
            .header {
                transition: none !important;
            }
            .header--filled:hover {
                transition: background-color .3s var(--transition-timing-function);
                --layout-bg-color: {{ section.settings.color_scheme.settings.layout_background_color.red }},{{ section.settings.color_scheme.settings.layout_background_color.green }},{{ section.settings.color_scheme.settings.layout_background_color.blue }} !important;
                {% if section.settings.color_scheme.settings.layout_background_gradient != empty %}
                --bg-gradient: {{ section.settings.color_scheme.settings.layout_background_gradient }} !important;
                {% else %}
                --bg-gradient: {{ section.settings.color_scheme.settings.layout_background_color }} !important;
                {% endif %}
                background: var(--bg-gradient) !important;
            }
            .header--filled:hover .main-header {
                --layout-text-color: {{ section.settings.color_scheme.settings.layout_text_color.red }},{{ section.settings.color_scheme.settings.layout_text_color.green }},{{ section.settings.color_scheme.settings.layout_text_color.blue }} !important;
                --layout-link-color: {{ section.settings.color_scheme.settings.layout_link_color.red }},{{ section.settings.color_scheme.settings.layout_link_color.green }},{{ section.settings.color_scheme.settings.layout_link_color.blue }} !important;
                --layout-highlighted-background: {{ section.settings.color_scheme.settings.layout_highlighted_background.red }},{{ section.settings.color_scheme.settings.layout_highlighted_background.green }},{{ section.settings.color_scheme.settings.layout_highlighted_background.blue }} !important;
                --layout-accent-color: {{ section.settings.color_scheme.settings.layout_accent_color.red }},{{ section.settings.color_scheme.settings.layout_accent_color.green }},{{ section.settings.color_scheme.settings.layout_accent_color.blue }} !important;
            }
        {% else %}
            .header--filled:hover .main-header {
                transition: background-color .3s var(--transition-timing-function);
                --layout-bg-color: {{ section.settings.color_scheme.settings.layout_background_color.red }},{{ section.settings.color_scheme.settings.layout_background_color.green }},{{ section.settings.color_scheme.settings.layout_background_color.blue }} !important;
                {% if section.settings.color_scheme.settings.layout_background_gradient != empty %}
                --bg-gradient: {{ section.settings.color_scheme.settings.layout_background_gradient }} !important;
                {% else %}
                --bg-gradient: {{ section.settings.color_scheme.settings.layout_background_color }} !important;
                {% endif %}
                --layout-text-color: {{ section.settings.color_scheme.settings.layout_text_color.red }},{{ section.settings.color_scheme.settings.layout_text_color.green }},{{ section.settings.color_scheme.settings.layout_text_color.blue }} !important;
                --layout-link-color: {{ section.settings.color_scheme.settings.layout_link_color.red }},{{ section.settings.color_scheme.settings.layout_link_color.green }},{{ section.settings.color_scheme.settings.layout_link_color.blue }} !important;
                --layout-highlighted-background: {{ section.settings.color_scheme.settings.layout_highlighted_background.red }},{{ section.settings.color_scheme.settings.layout_highlighted_background.green }},{{ section.settings.color_scheme.settings.layout_highlighted_background.blue }} !important;
                --layout-accent-color: {{ section.settings.color_scheme.settings.layout_accent_color.red }},{{ section.settings.color_scheme.settings.layout_accent_color.green }},{{ section.settings.color_scheme.settings.layout_accent_color.blue }} !important;
                background: var(--bg-gradient) !important;
            }
        {% endif %}
        .header--filled:hover .bottom-bar {
            transition: background-color .3s var(--transition-timing-function);
            --layout-bg-color: {{ section.settings.bottom_color_scheme.settings.layout_background_color.red }},{{ section.settings.bottom_color_scheme.settings.layout_background_color.green }},{{ section.settings.bottom_color_scheme.settings.layout_background_color.blue }} !important;
            {% if section.settings.bottom_color_scheme.settings.layout_background_gradient != empty %}
            --bg-gradient: {{ section.settings.bottom_color_scheme.settings.layout_background_gradient }} !important;
            {% else %}
            --bg-gradient: {{ section.settings.bottom_color_scheme.settings.layout_background_color }} !important;
            {% endif %}
            --layout-text-color: {{ section.settings.bottom_color_scheme.settings.layout_text_color.red }},{{ section.settings.bottom_color_scheme.settings.layout_text_color.green }},{{ section.settings.bottom_color_scheme.settings.layout_text_color.blue }} !important;
            --layout-link-color: {{ section.settings.bottom_color_scheme.settings.layout_link_color.red }},{{ section.settings.bottom_color_scheme.settings.layout_link_color.green }},{{ section.settings.bottom_color_scheme.settings.layout_link_color.blue }} !important;
            --layout-highlighted-background: {{ section.settings.bottom_color_scheme.settings.layout_highlighted_background.red }},{{ section.settings.bottom_color_scheme.settings.layout_highlighted_background.green }},{{ section.settings.bottom_color_scheme.settings.layout_highlighted_background.blue }} !important;
            --layout-accent-color: {{ section.settings.bottom_color_scheme.settings.layout_accent_color.red }},{{ section.settings.bottom_color_scheme.settings.layout_accent_color.green }},{{ section.settings.bottom_color_scheme.settings.layout_accent_color.blue }} !important;
            background: var(--bg-gradient) !important;
        }
    }
    body.search-modal--open .header--filled .main-header {
        transition: background-color .3s var(--transition-timing-function);
        --layout-bg-color: {{ section.settings.color_scheme.settings.layout_background_color.red }},{{ section.settings.color_scheme.settings.layout_background_color.green }},{{ section.settings.color_scheme.settings.layout_background_color.blue }} !important;
        {% if section.settings.color_scheme.settings.layout_background_gradient != empty %}
        --bg-gradient: {{ section.settings.color_scheme.settings.layout_background_gradient }} !important;
        {% else %}
        --bg-gradient: {{ section.settings.color_scheme.settings.layout_background_color }} !important;
        {% endif %}
        --layout-text-color: {{ section.settings.color_scheme.settings.layout_text_color.red }},{{ section.settings.color_scheme.settings.layout_text_color.green }},{{ section.settings.color_scheme.settings.layout_text_color.blue }} !important;
        --layout-link-color: {{ section.settings.color_scheme.settings.layout_link_color.red }},{{ section.settings.color_scheme.settings.layout_link_color.green }},{{ section.settings.color_scheme.settings.layout_link_color.blue }} !important;
        --layout-highlighted-background: {{ section.settings.color_scheme.settings.layout_highlighted_background.red }},{{ section.settings.color_scheme.settings.layout_highlighted_background.green }},{{ section.settings.color_scheme.settings.layout_highlighted_background.blue }} !important;
        --layout-accent-color: {{ section.settings.color_scheme.settings.layout_accent_color.red }},{{ section.settings.color_scheme.settings.layout_accent_color.green }},{{ section.settings.color_scheme.settings.layout_accent_color.blue }} !important;
        background: var(--bg-gradient) !important;
    }
    body.search-modal--open .header--filled .bottom-bar {
        --layout-bg-color: {{ section.settings.bottom_color_scheme.settings.layout_background_color.red }},{{ section.settings.bottom_color_scheme.settings.layout_background_color.green }},{{ section.settings.bottom_color_scheme.settings.layout_background_color.blue }} !important;
        {% if section.settings.bottom_color_scheme.settings.layout_background_gradient != empty %}
        --bg-gradient: {{ section.settings.bottom_color_scheme.settings.layout_background_gradient }} !important;
        {% else %}
        --bg-gradient: {{ section.settings.bottom_color_scheme.settings.layout_background_color }} !important;
        {% endif %}
        --layout-text-color: {{ section.settings.bottom_color_scheme.settings.layout_text_color.red }},{{ section.settings.bottom_color_scheme.settings.layout_text_color.green }},{{ section.settings.bottom_color_scheme.settings.layout_text_color.blue }} !important;
        --layout-link-color: {{ section.settings.bottom_color_scheme.settings.layout_link_color.red }},{{ section.settings.bottom_color_scheme.settings.layout_link_color.green }},{{ section.settings.bottom_color_scheme.settings.layout_link_color.blue }} !important;
        --layout-highlighted-background: {{ section.settings.bottom_color_scheme.settings.layout_highlighted_background.red }},{{ section.settings.bottom_color_scheme.settings.layout_highlighted_background.green }},{{ section.settings.bottom_color_scheme.settings.layout_highlighted_background.blue }} !important;
        --layout-accent-color: {{ section.settings.bottom_color_scheme.settings.layout_accent_color.red }},{{ section.settings.bottom_color_scheme.settings.layout_accent_color.green }},{{ section.settings.bottom_color_scheme.settings.layout_accent_color.blue }} !important;
    }
    @media screen and (min-width: 769px) {
        .mega-menu-opened .header--filled .main-header {
            transition: background-color .3s var(--transition-timing-function);
            --layout-bg-color: {{ section.settings.color_scheme.settings.layout_background_color.red }},{{ section.settings.color_scheme.settings.layout_background_color.green }},{{ section.settings.color_scheme.settings.layout_background_color.blue }} !important;
            {% if section.settings.color_scheme.settings.layout_background_gradient != empty %}
            --bg-gradient: {{ section.settings.color_scheme.settings.layout_background_gradient }} !important;
            {% else %}
            --bg-gradient: {{ section.settings.color_scheme.settings.layout_background_color }} !important;
            {% endif %}
            --layout-text-color: {{ section.settings.color_scheme.settings.layout_text_color.red }},{{ section.settings.color_scheme.settings.layout_text_color.green }},{{ section.settings.color_scheme.settings.layout_text_color.blue }} !important;
            --layout-link-color: {{ section.settings.color_scheme.settings.layout_link_color.red }},{{ section.settings.color_scheme.settings.layout_link_color.green }},{{ section.settings.color_scheme.settings.layout_link_color.blue }} !important;
            --layout-highlighted-background: {{ section.settings.color_scheme.settings.layout_highlighted_background.red }},{{ section.settings.color_scheme.settings.layout_highlighted_background.green }},{{ section.settings.color_scheme.settings.layout_highlighted_background.blue }} !important;
            --layout-accent-color: {{ section.settings.color_scheme.settings.layout_accent_color.red }},{{ section.settings.color_scheme.settings.layout_accent_color.green }},{{ section.settings.color_scheme.settings.layout_accent_color.blue }} !important;
            background: var(--bg-gradient) !important;
        }
        .mega-menu-opened .header--filled .bottom-bar {
            transition: background-color .3s var(--transition-timing-function);
            --layout-bg-color: {{ section.settings.bottom_color_scheme.settings.layout_background_color.red }},{{ section.settings.bottom_color_scheme.settings.layout_background_color.green }},{{ section.settings.bottom_color_scheme.settings.layout_background_color.blue }} !important;
            {% if section.settings.bottom_color_scheme.settings.layout_background_gradient != empty %}
            --bg-gradient: {{ section.settings.bottom_color_scheme.settings.layout_background_gradient }} !important;
            {% else %}
            --bg-gradient: {{ section.settings.bottom_color_scheme.settings.layout_background_color }} !important;
            {% endif %}
            --layout-text-color: {{ section.settings.bottom_color_scheme.settings.layout_text_color.red }},{{ section.settings.bottom_color_scheme.settings.layout_text_color.green }},{{ section.settings.bottom_color_scheme.settings.layout_text_color.blue }} !important;
            --layout-link-color: {{ section.settings.bottom_color_scheme.settings.layout_link_color.red }},{{ section.settings.bottom_color_scheme.settings.layout_link_color.green }},{{ section.settings.bottom_color_scheme.settings.layout_link_color.blue }} !important;
            --layout-highlighted-background: {{ section.settings.bottom_color_scheme.settings.layout_highlighted_background.red }},{{ section.settings.bottom_color_scheme.settings.layout_highlighted_background.green }},{{ section.settings.bottom_color_scheme.settings.layout_highlighted_background.blue }} !important;
            --layout-accent-color: {{ section.settings.bottom_color_scheme.settings.layout_accent_color.red }},{{ section.settings.bottom_color_scheme.settings.layout_accent_color.green }},{{ section.settings.bottom_color_scheme.settings.layout_accent_color.blue }} !important;
            background: var(--bg-gradient) !important;
        }
    }
    @media screen and (max-width: 768px) {
        #shopify-section-{{ section.id }} {
        --top-and-bottom-paddings: {{ section.settings.mobile_top_and_bottom_spacing }}px;
    }
    }
{% endstyle %}

{% liquid 
    assign disable_max_width = false
    if section.settings.disable_max_width 
      assign disable_max_width = true
    elsif section.settings.grid_style == 'page' and settings.full_width_page_grid
      assign disable_max_width = true
    elsif section.settings.grid_style == 'alternative' and settings.full_width_alt_grid
      assign disable_max_width = true
    elsif section.settings.grid_style == 'secondary' and settings.full_width_second_grid
      assign disable_max_width = true
    endif

    if section.settings.header_layout contains 'menu_left'
        assign menu_alignment = 'flex-start'
    else 
        assign menu_alignment = 'center'
    endif 
    assign mega_menu_enabled = false
    for block in section.blocks
        if block.type == 'mega_menu' or block.type == 'short_mega_menu'
            assign mega_menu_enabled = true
        endif
    endfor
%}

<sticky-header>
    <header class="header{% if section.settings.sticky_header == 'always' %} header--always-stick{% endif %} header--{{ section.settings.sticky_header }}-stick {% if section.settings.hide_header_bg %} header--transparent{% endif %}{% if section.settings.show_header_bg_on_hover %} header--filled{% endif %}{% if section.settings.show_bottom_line %} header--border{% endif %}" data-sticky-type="{{ section.settings.sticky_header }}">
        <div class="main-header gradient color-{{ section.settings.color_scheme }} {{ section.settings.header_layout }} {{ section.settings.mobile_header_layout }} burger-{{ section.settings.burger_position }}">
            <div class="main-header-wrapper side-margins {{ section.settings.grid_style }}-grid{% if disable_max_width %} disable-max-width{% endif %}{% if section.settings.color_scheme == section.settings.bottom_color_scheme and section.settings.bottom_show_line == false %} reduce-padding{% endif %}">
                {% if section.settings.header_layout != 'logo_center_menu_left' or section.settings.header_layout != 'logo_center_search_left' or section.settings.header_layout != 'logo_center_menu_split' %}
                <div class="header-segment-1 header-segment-desktop flex--row">
                    {% if section.settings.header_layout == 'logo_left_menu_left' or section.settings.header_layout == 'logo_left_menu_center' or section.settings.header_layout == 'logo_left_wide_search' %}
                        {% if section.settings.show_burger and section.settings.burger_position == 'left' %}
                            <div class="burger-menu">
                                <menu-drawer>
                                    <button class="burger-js burger-menu-button flex--row" data-modal-toggle-menu-dawer aria-label="{{ 'general.burger_menu' | t }}">
                                        {% if section.settings.burger_style == 'icon' or section.settings.burger_style == 'icon_with_text' %}
                                            {% liquid 
                                                if settings.burger_icon == 'classic'
                                                    assign icon = 'menu'
                                                else 
                                                    assign icon = 'menu-2-stripes'
                                                endif
                                            %}
                                            {%- render 'glyphs_header', icon: icon -%}
                                        {% endif %}
                                        {% if section.settings.burger_style == 'text' or section.settings.burger_style == 'icon_with_text' %}
                                            <span class="{{ section.settings.elements_text_style }}{% if section.settings.elements_text_style == 'subheading-font' and settings.use_heading_font_subheadings %} subheading-heading-font{% endif %}{% if section.settings.elements_uppercase %} uppercase{% endif %}">{% if section.settings.elements_bolder_font %}<b>{% endif %}{{ 'general.burger_menu_title' | t }}{% if section.settings.elements_bolder_font %}</b>{% endif %}</span>
                                        {% endif %}
                                    </button>
                                </menu-drawer>
                            </div>
                        {% endif %}
                        {% liquid 
                            for block in section.blocks
                                case block.type
                                when 'logo'
                                    render 'logo', object_type: block
                                endcase
                            endfor
                        %}
                    {% endif %}
                </div>
                {% endif %}
                <div class="header-segment-2 header-segment-desktop">
                    {% if section.settings.show_burger and section.settings.burger_position == 'left' and section.settings.header_layout != 'logo_left_menu_left' and section.settings.header_layout != 'logo_left_menu_center' and section.settings.header_layout != 'logo_left_wide_search' %}
                        <div class="burger-menu">
                            <menu-drawer>
                                <button class="burger-js burger-menu-button flex--row" data-modal-toggle-menu-dawer aria-label="{{ 'general.burger_menu' | t }}">
                                    {% if section.settings.burger_style == 'icon' or section.settings.burger_style == 'icon_with_text' %}
                                        {% liquid 
                                            if settings.burger_icon == 'classic'
                                                assign icon = 'menu'
                                            else 
                                                assign icon = 'menu-2-stripes'
                                            endif
                                        %}
                                        {%- render 'glyphs_header', icon: icon -%}
                                    {% endif %}
                                    {% if section.settings.burger_style == 'text' or section.settings.burger_style == 'icon_with_text' %}
                                        <span class="{{ section.settings.elements_text_style }}{% if section.settings.elements_text_style == 'subheading-font' and settings.use_heading_font_subheadings %} subheading-heading-font{% endif %}{% if section.settings.elements_uppercase %} uppercase{% endif %}">{% if section.settings.elements_bolder_font %}<b>{% endif %}{{ 'general.burger_menu_title' | t }}{% if section.settings.elements_bolder_font %}</b>{% endif %}</span>
                                    {% endif %}
                                </button>
                            </menu-drawer>
                        </div>
                    {% endif %}
                    {% if section.settings.header_layout == 'logo_left_menu_left' or section.settings.header_layout == 'logo_left_menu_center' or section.settings.header_layout == 'logo_center_menu_left' %}
                        {% render 'menu', menu: section.settings.menu, horizontal_alignment: menu_alignment, object_type: section, event_type: section.settings.dropdown_event_type, blocks: section.blocks, show_nested: true, link_style: section.settings.link_style, uppercase: section.settings.uppercase, bolder_font: section.settings.bolder_font, parent_menu: section.settings.parent_menu, dropdown_icon: section.settings.dropdown_icon %}
                    {% endif %}
                    {% if section.settings.header_layout == 'logo_left_wide_search' or section.settings.header_layout == 'logo_center_menu_split' or section.settings.header_layout == 'logo_center_search_left' %}
                        {% if section.settings.show_search %}
                            {% render 'search', show_account: section.settings.show_account, search_style: section.settings.search_style, search_field_radius: section.settings.search_field_radius, fill_search_background: section.settings.fill_search_background, show_search_outline: section.settings.show_search_outline %}
                        {% endif %}
                    {% endif %}
                </div>
                {% if section.settings.header_layout == 'logo_center_menu_left' or section.settings.header_layout == 'logo_center_search_left' %}
                    <div class="header-segment-1 header-segment-desktop flex--row">
                            {% liquid 
                                for block in section.blocks
                                    case block.type
                                    when 'logo'
                                        render 'logo', object_type: block
                                    endcase
                                endfor
                            %}
                    </div>
                {% endif %}
                {% if section.settings.header_layout == 'logo_center_menu_split' %}
                    <div class="header-segment-1 header-segment-desktop flex--row">
                            {% assign first_menu_part = section.settings.menu.links.size | divided_by: 2 | floor %}
                            {% render 'first-part-menu', first_links_size: first_menu_part, menu: section.settings.menu, object_type: section, horizontal_alignment: 'flex-end', event_type: section.settings.dropdown_event_type, show_nested: true, link_style: section.settings.link_style, uppercase: section.settings.uppercase, bolder_font: section.settings.bolder_font, blocks: section.blocks, parent_menu: section.settings.parent_menu, dropdown_icon: section.settings.dropdown_icon %}
                            {% liquid 
                                for block in section.blocks
                                    case block.type
                                    when 'logo'
                                        render 'logo', object_type: block
                                    endcase
                                endfor
                            %}
                            {% render 'last-part-menu', first_links_size: first_menu_part, menu: section.settings.menu, object_type: section, horizontal_alignment: 'flex-start', event_type: section.settings.dropdown_event_type, show_nested: true, link_style: section.settings.link_style, uppercase: section.settings.uppercase, bolder_font: section.settings.bolder_font, blocks: section.blocks, parent_menu: section.settings.parent_menu, dropdown_icon: section.settings.dropdown_icon %}
                    </div>
                {% endif %}
                <div class="header-segment-3 header-segment-desktop">
                    {% if section.settings.header_layout == 'logo_left_menu_left' or section.settings.header_layout == 'logo_left_menu_center' or section.settings.header_layout == 'logo_left_wide_search' or section.settings.header_layout == 'logo_center_menu_left' or section.settings.header_layout == 'logo_center_menu_split' or section.settings.header_layout == 'logo_center_search_left' %}
                        <div class="icons flex--row body-font">
                            {% if section.settings.enable_store_selector %}
                                {% render 'store-selector' %}
                            {% endif %}

                            {% liquid 
                                assign enable_lang = false
                                    if section.settings.enable_language and localization.available_languages.size > 1
                                        assign enable_lang = true
                                    endif
                                assign enable_country = false
                                    if section.settings.enable_country and localization.available_countries.size > 1
                                        assign enable_lang = true
                                    endif
                                if enable_lang or enable_country
                                    render 'localization', object_type: section, show_localization_chevron: section.settings.show_localization_chevron, localization_radius: section.settings.localization_radius, show_outline: section.settings.show_localization_outline, show_flag: section.settings.show_localization_flag, text_style: section.settings.elements_text_style, uppercase: section.settings.elements_uppercase, bolder: section.settings.elements_bolder_font
                                endif
                                if section.settings.show_search and section.settings.header_layout != 'logo_left_wide_search' and section.settings.header_layout != 'logo_center_search_left' and section.settings.header_layout != 'logo_center_menu_split'
                                    render 'search', show_account: section.settings.show_account, search_style: section.settings.search_style, search_field_radius: section.settings.search_field_radius, fill_search_background: section.settings.fill_search_background, show_search_outline: section.settings.show_search_outline, text_style: section.settings.elements_text_style, uppercase: section.settings.elements_uppercase, bolder: section.settings.elements_bolder_font
                                endif
                            %}                        
                            {%- if section.settings.show_account and shop.customer_accounts_enabled -%}
                                <a href="{{ routes.account_url }}" class="account header-element {{ section.settings.elements_text_style }}{% if section.settings.elements_text_style == 'subheading-font' and settings.use_heading_font_subheadings %} subheading-heading-font{% endif %} flex--row{% if section.settings.elements_uppercase %} uppercase{% endif %}" aria-label="{{ 'customer.account.go_to_account' | t }}">
                                    {% if section.settings.account_style == 'icon' or section.settings.account_style == 'icon_with_text' %}
                                        <span class="flex--row icon icon--large">{%- render 'glyphs_header', icon: 'user' -%}</span>
                                    {% endif %}
                                    {% if section.settings.account_style == 'text' or section.settings.account_style == 'icon_with_text' %}
                                        <span>{% if section.settings.elements_bolder_font %}<b>{% endif %}{{ 'customer.account.title' | t }}{% if section.settings.elements_bolder_font %}</b>{% endif %}</span>
                                    {% endif %}
                                </a>
                            {%- endif -%}
                            {% if settings.disable_shopping == false %}
                                <div class="cart-icon" id="cart-link">
                                    <a class="cart flex--row header-element align-center {{ section.settings.elements_text_style }}{% if section.settings.elements_text_style == 'subheading-font' and settings.use_heading_font_subheadings %} subheading-heading-font{% endif %}{% if section.settings.elements_uppercase %} uppercase{% endif %}" href="{{ routes.cart_url }}" id="cart-icon-bubble-{{ section.id }}" aria-label="{% if settings.cart_name == 'cart' %}{{ 'cart.title_cart' | t }}{% elsif settings.cart_name == 'bag' %}{{ 'cart.title_bag' | t }}{% elsif settings.cart_name == 'basket' %}{{ 'cart.title_basket' | t }}{% endif %}">
                                        {% if section.settings.cart_style == 'icon' or section.settings.cart_style == 'icon_with_text' %}
                                            <span class="cart__icon icon icon--large flex--row">
                                                {% assign icon = settings.cart_name %}
                                                {%- render 'glyphs_header', icon: icon -%}
                                            </span>
                                        {% endif %}
                                        {% if section.settings.cart_style == 'text' or section.settings.cart_style == 'icon_with_text' %}
                                            <span class="cart__title">
                                                {% if section.settings.elements_bolder_font %}<b>{% endif %}
                                                {% if settings.cart_name == 'cart' %}
                                                    {{ 'cart.title_cart' | t }}
                                                {% elsif settings.cart_name == 'bag' %}
                                                    {{ 'cart.title_bag' | t }}
                                                {% elsif settings.cart_name == 'basket' %}
                                                    {{ 'cart.title_basket' | t }}
                                                {% endif %}
                                                {% if section.settings.elements_bolder_font %}</b>{% endif %}
                                            </span>
                                        {% endif %}
                                        {% if cart.item_count > 0 or section.settings.cart_style == 'number' %}
