<custom-options class="custom-options custom-options--radio custom-options--{{ block.id }} flex--column product-form__input" style="--spacing: {{ block.settings.top_spacing }};--mobile-spacing: {{ block.settings.mobile_top_spacing }};" {{ block.shopify_attributes }}>
    {% style %}
        .custom-options--{{ block.id }} {
            --swatches-radius: {{ block.settings.swatches_radius }};
            --custom-swatch-width: {{ block.settings.swatch_size }}px;
            --swatches-aspect-ratio: {{ block.settings.swatches_image_ratio }};
            --swatches-focal-point: {{ block.settings.swatches_focal_point }};
        }
        @media screen and (max-width: 768px) {
            .custom-options--{{ block.id }} {
                --custom-swatch-width: {{ block.settings.swatch_size_mobile }}px;
            }
        }
    {% endstyle %}
    {% liquid 
      assign product_form_id = 'product-form-' | append: section.id
      assign options = block.settings.options | split: ','
      assign default_option = ''
      if settings.show_selected_option
        for option in options
            if forloop.first
                assign default_option = option
                break
            endif
        endfor
      endif
    %}
    {% if settings.show_label and block.settings.option_label != blank %}
        <p class="form__label {{ block.settings.label_style }}{% if block.settings.label_uppercase %} uppercase{% endif %}{% if block.settings.label_style == 'subheading-font' and settings.use_heading_font_subheadings %} subheading-heading-font{% endif %}">
            <tooltip-component class="tooltip form__label-name">
                {% if block.settings.label_bolder_font %}<b>{% endif %}{{ block.settings.option_label }}{% if block.settings.label_bolder_font %}</b>{% endif %}
                {% if block.settings.info_tooltip != blank %}
                    <span class="tooltip__icon icon icon--small">
                        {%- render 'glyphs_signs', icon: 'help' -%}
                        <span class="tooltip__text caption-font{% if settings.uppercase_caption %} uppercase{% else %} none-uppercase{% endif %}">{{ block.settings.info_tooltip }}</span>
                    </span>
                {% endif %}
            </tooltip-component>
            {% if settings.show_selected_option %} 
                {% if block.settings.label_bolder_font %}<b>{% endif %}
                <span class="current-option" data-selected-custom-option>&#x2014; {{  default_option }}</span>
                {% if block.settings.label_bolder_font %}</b>{% endif %}
            {% endif %}
        </p>
    {% endif %}
    {% if options.size > 0 %}
    <div class="form__variants layout-row {{ block.settings.text_style }}{% if block.settings.text_uppercase %} uppercase{% endif %}{% if block.settings.text_style == 'subheading-font' and settings.use_heading_font_subheadings %} subheading-heading-font{% endif %}">
        {% for option in options %}
            {% liquid
                assign swatch_file_extension = 'png'

                capture color_file_name
                    render 'filename-normalize', value: option, keep_case: true
                endcapture
                assign color_file_name = color_file_name | append: '.' | append: swatch_file_extension

                capture color_value
                    render 'filename-normalize', value: option
                endcapture

                assign img_file = images[color_file_name] | downcase
                assign color_image = images[color_file_name] | split: '/' | last | file_img_url: '248x248' | prepend: 'https:' | split: '?' | first
            %}
            <input type="radio" id="{{ block.id }}-{{ block.settings.option_name }}-{{ forloop.index0 }}"
            name="properties[{{ block.settings.option_name }}]"
            value="{{ option | escape }}"
            {% if value.selected or forloop.first %}checked{% endif %}
            form="{{ product_form_id }}"
            {% if from_details %}
                data-place-for-id="{{ block.id }}-{{ block.settings.option_name }}-{{ forloop.index0 }}"
                data-place-for-name="properties[{{ block.settings.option_name }}]"
                data-form-input="{{ product_form_id }}"
                {% if value.selected or forloop.first %}data-checked{% endif %}
            {% endif %}
            >
            <label for="{{ block.id }}-{{ block.settings.option_name }}-{{ forloop.index0 }}" class="color__swatch color__swatch--color" 
                style="{% if images[color_file_name] != blank and img_file contains color_value %}--swatch-background: url({{ color_image }}); --swatch-background-color: {{ option }};{% else %}--swatch-background: {{ option }}; --swatch-background-color: {{ option }};{% endif %}">
                <span class="color__swatch-dot color__swatch-dot--color"></span>
                <span class="color__swatch-name">{% if block.settings.text_bolder_font %}<b>{% endif %}{{ value }}{% if block.settings.text_bolder_font %}</b>{% endif %}</span>
                <span class="color__swatch-tooltip caption-font{% if settings.uppercase_caption %} uppercase{% else %} none-uppercase{% endif %}">{{ option }}</span>
            </label>
        {% endfor %}
    </div>
    {% endif %}
</custom-options>