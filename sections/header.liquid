                                {% endstyle %}
                            
                                {% render 'menu', menu: linklists[link_handle], horizontal_alignment: section.settings.bottom_menu_alignment, object_type: section, event_type: section.settings.bottom_dropdown_event_type, blocks: section.blocks, show_nested: true, link_style: section.settings.bottom_link_style, uppercase: section.settings.bottom_uppercase, bolder_font: section.settings.bottom_bolder_font, dropdown_icon: section.settings.bottom_dropdown_icon %}
                            {% endif %}
