                                    .header:has(.main-header-wrapper .active-parent-link.link-{{ link_handle }}) .main-header:has( ~ .bottom-bar.sections-paddings .menu.menu-{{ link_handle }}) .main-header-wrapper {
                                        padding-top: var(--top-and-bottom-paddings);
                                        padding-bottom: var(--top-and-bottom-paddings);
                                    }
                                    .header:has(.main-header-wrapper .active-parent-link.link-{{ link_handle }}) .bottom-bar.sections-paddings:has(.menu.menu-{{ link_handle }}) {
                                        padding-top: var(--top-and-bottom-paddings);
                                        padding-bottom: var(--top-and-bottom-paddings);
